# Copie este arquivo para .env e preencha com seus valores reais.
# (O .env não vai para o git; este .env.example serve de referência.)

# ===== Django =====
# Gere uma SECRET_KEY com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-secreta
DEBUG=True
# Hosts permitidos, separados por vírgula. Em produção, ex.:
#   ALLOWED_HOSTS=seu-usuario.pythonanywhere.com
ALLOWED_HOSTS=

# ===== Banco de dados =====
# Por padrão usa SQLite (nada a configurar) — ideal para o PythonAnywhere free.
# Para usar PostgreSQL, descomente DB_ENGINE e preencha as variáveis DB_*.
# DB_ENGINE=postgres
# DB_NAME=scholarhub_db
# DB_USER=seu_usuario_postgres
# DB_PASSWORD=sua_senha_postgres
# DB_HOST=localhost
# DB_PORT=5432

# ===== E-mail (código OTP de confirmação de cadastro) =====
# Ordem de prioridade: Resend (API HTTP) > SMTP > console (imprime no terminal).
#
# OPÇÃO 1 — Resend (RECOMENDADO no PythonAnywhere free): usa a API HTTP, que
# passa pelo proxy. O SMTP é bloqueado no plano grátis; a API do Resend, não.
# O 'from' precisa ser de um domínio verificado no Resend; para testar, use
# onboarding@resend.dev (só envia para o e-mail dono da conta Resend).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=ScholarHub <onboarding@resend.dev>
#
# OPÇÃO 2 — SMTP (só em conta PAGA do PythonAnywhere). Ex. Gmail com SENHA DE APP:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=seu@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app
# DEFAULT_FROM_EMAIL=ScholarHub <seu@gmail.com>
